# Maintainer: Alexey Pavlov <alexpux@gmail.com>

_realname=swig
pkgbase=mingw-w64-${_realname}
pkgname="${MINGW_PACKAGE_PREFIX}-${_realname}"
pkgver=4.4.1
pkgrel=1
pkgdesc="Generate scripting interfaces to C/C++ code (mingw-w64)"
arch=('any')
mingw_arch=('mingw32' 'mingw64' 'ucrt64' 'clang64' 'clangarm64')
url="https://www.swig.org/"
msys2_repository_url="https://github.com/swig/swig"
license=('custom')
depends=("${MINGW_PACKAGE_PREFIX}-cc-libs"
         "${MINGW_PACKAGE_PREFIX}-pcre2")
makedepends=("${MINGW_PACKAGE_PREFIX}-cc"
             "${MINGW_PACKAGE_PREFIX}-autotools")
checkdepends=("${MINGW_PACKAGE_PREFIX}-boost"
              "${MINGW_PACKAGE_PREFIX}-python"
              "${MINGW_PACKAGE_PREFIX}-lua"
              "${MINGW_PACKAGE_PREFIX}-ruby")
source=(https://downloads.sourceforge.net/${_realname}/${_realname}-${pkgver}.tar.gz
        001-relocate.patch
        0001-Guile-Use-correct-int-conversions-for-ptrs-and-size_.patch)
sha256sums=('40162a706c56f7592d08fd52ef5511cb7ac191f3593cf07306a0a554c6281fcf'
            '87d905560e432661fbf44b6b65b9957abb91f2067796b5195c991a33cf6d73fa'
            '618d20c206c201e45b4e552467f7c1581eeb83a66274007c8d9583e9b4a26a2a')

prepare() {
  cd "${srcdir}/${_realname}-${pkgver}"
  cp -fHv "${startdir}"/pathtools.[ch] Source/Swig/

  patch -p1 -i "${srcdir}"/001-relocate.patch

  patch -p1 -i "${srcdir}"/0001-Guile-Use-correct-int-conversions-for-ptrs-and-size_.patch

  ./autogen.sh

    rm -rf "${srcdir}/build-${MSYSTEM}"
    mkdir -p "${srcdir}/build-${MSYSTEM}"

}

build() {
    echo "\n\nMachine Type  ${MACHTYPE}\n\n"
    cd "${srcdir}/build-${MSYSTEM}"

  ../${_realname}-${pkgver}/configure\
    --prefix=${MINGW_PREFIX} \
    --without-perl5 \
    --without-python \
    --with-guile=${MINGW_PREFIX}/bin/guile \
    --with-guile-cflags="-I${MINGW_PREFIX}/include/guile/3.0" \
    --with-guile-libs="-lguile3.0 -lgc" \
    --with-python3=${MINGW_PREFIX}/bin/python \
    $@

  make
}

# Many tests depend on the javascript shell that in turn depends on dlfcn.h. That's a POSIX header not available in Windows.
#check() {
#  cd "${srcdir}/build-${MSYSTEM}"
#  make -k check
#}

package() {
  cd "${srcdir}/build-${MSYSTEM}"
  make DESTDIR="${pkgdir}" install
  install -Dm644 "${srcdir}"/${_realname}-${pkgver}/LICENSE "${pkgdir}${MINGW_PREFIX}"/share/licenses/${_realname}/LICENSE
  install -Dm644 "${srcdir}"/${_realname}-${pkgver}/LICENSE-UNIVERSITIES "${pkgdir}${MINGW_PREFIX}"/share/licenses/${_realname}/LICENSE-UNIVERSITIES
}
