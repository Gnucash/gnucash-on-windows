_realname=libdbi
pkgbase="${MINGW_PACKAGE_PREFIX}-${_realname}"
pkgname=${pkgbase}
pkgver=0.9.1
pkgrel=1
pkgdesc="SQL Abstraction Library"
arch=('any')
mingw_arch=('mingw32' 'mingw64' 'ucrt64' 'clang64' 'clangarm64')
url="http://downloads.sourceforge.net/gnucash"
license=('GPL-2.0-only')
options=('!libtool' 'debug' 'strip' 'buildflags')
makedepends=("${MINGW_PACKAGE_PREFIX}-gcc")
depends=("${MINGW_PACKAGE_PREFIX}-libtool")
source=(${url}/${_realname}-${pkgver}.tar.gz
       libdbi-timegm.patch)
prepare() {
    cd ${srcdir}/${_realname}-${pkgver}/

    # Put patch commands here
    patch -p1 -i ${srcdir}/libdbi-timegm.patch
    # autoreconf --install
    rm -rf ${srcdir}/build
    mkdir ${srcdir}/build
}

build() {
    cd "${srcdir}/build"
    ${srcdir}/${_realname}-${pkgver}/configure \
    --prefix=${MINGW_PREFIX} \
    --build=${MINGW_CHOST} \
    --host=${MINGW_CHOST} \
    --disable-static \
    --enable-shared \
    --disable-docs \
    "$@"

    make
}

package() {
    cd "${srcdir}/build"
    make -j1 DESTDIR="${pkgdir}" install
}

sha256sums=('870c81447e45ea7f02379dec91ca53f0a28c2438cf88bb3a6491fb4db30db528'
           '67739b909b5e4961eaab41b537c776038e2c995cbcb4123e376644be42a1d056')
